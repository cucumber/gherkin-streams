{
  "name": "@cucumber/gherkin-streams",
  "version": "6.0.0",
  "description": "Streams for reading Gherkin parser output",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "gherkin-javascript": "bin/gherkin"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/cucumber/gherkin-streams.git"
  },
  "author": "Cucumber Limited <cukes@googlegroups.com>",
  "license": "MIT",
  "scripts": {
    "test": "mocha",
    "build": "tsc --build tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "fix": "biome check --fix --error-on-warnings",
    "lint": "biome check --error-on-warnings"
  },
  "dependencies": {
    "commander": "14.0.3",
    "source-map-support": "0.5.21"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cucumber/biome-config": "github:cucumber/biome-config#v0.1.0",
    "@cucumber/gherkin": "^39.0.0",
    "@cucumber/message-streams": "^4.0.1",
    "@cucumber/messages": "^32.0.0",
    "@types/mocha": "10.0.10",
    "@types/node": "22.19.17",
    "mocha": "11.7.5",
    "nyc": "18.0.0",
    "ts-node": "^10.7.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@cucumber/gherkin": ">=22.0.0",
    "@cucumber/message-streams": ">=4.0.0",
    "@cucumber/messages": ">=17.1.1"
  },
  "bugs": {
    "url": "https://github.com/cucumber/gherkin-streams/issues"
  },
  "homepage": "https://github.com/cucumber/gherkin-streams#readme",
  "directories": {
    "test": "test"
  },
  "keywords": []
}
